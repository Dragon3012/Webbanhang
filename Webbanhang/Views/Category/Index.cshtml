@model IEnumerable<Webbanhang.Models.Category>

@{
    ViewData["Title"] = "Danh sách danh mục";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Danh sách danh mục sản phẩm</h2>
        <a asp-action="Add" class="btn btn-success">
            Thêm danh mục mới
        </a>
    </div>

    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Mã số (Id)</th>
                <th>Tên danh mục</th>
                <th class="text-center" style="width: 200px;">Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Name</td>
                        <td class="text-center">
                            <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                Sửa
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                Xóa
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="3" class="text-center text-muted">Chưa có danh mục nào được khởi tạo hệ thống.</td>
                </tr>
            }
        </tbody>
    </table>
</div>